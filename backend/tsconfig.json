{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",       // include both src/ and scripts/
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src", "scripts"]
}
